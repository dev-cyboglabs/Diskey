<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Diskey" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Diskey.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0E1A</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/ic_menu_info_details</item>
        <item name="postSplashScreenTheme">@style/Theme.Diskey</item>
    </style>
</resources>
